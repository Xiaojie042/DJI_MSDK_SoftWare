# === 服务端口 ===
TCP_SERVER_HOST=0.0.0.0
TCP_SERVER_PORT=8888
API_HOST=0.0.0.0
API_PORT=8000

# === MQTT 配置 (本地 EMQX) ===
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=drone-monitor-backend
MQTT_TOPIC_PREFIX=drone/telemetry

# === 数据库 ===
DATABASE_URL=sqlite+aiosqlite:///./drone_monitor.db

# === 日志 ===
LOG_LEVEL=INFO
